# Chave da API Anthropic (obrigatório para extração via LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a usar (padrão: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Caminho do banco SQLite (padrão: data/catalog.db)
DATABASE_URL=sqlite:///data/catalog.db

# Intervalo do polling em horas (padrão: 24)
POLLING_INTERVAL_HOURS=24

# Porta da API (padrão: 8000)
API_PORT=8000
